# Artefactos de compilación de arduino-cli (se regeneran al compilar)
build/
*.bin
*.elf
*.hex
*.map

# Compilados LaTeX (intermedios de pdflatex/biber — el .pdf sí se versiona)
memoria/*.aux
memoria/*.bbl
memoria/*.bcf
memoria/*.blg
memoria/*.log
memoria/*.out
memoria/*.run.xml
memoria/*.toc
memoria/*.synctex.gz
memoria/secciones/*.aux

# Caches de Python (preprocesador de la memoria)
__pycache__/
*.pyc

# Configuración local del editor / IDE
.vscode/
.idea/

# Carpeta local de Claude Code
.claude/

# Archivos temporales de Office y del SO
~$*
.DS_Store
Thumbs.db
*.swp
*~
